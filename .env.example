# 환경변수 예시 — 실제 값은 이 파일에 넣지 않는다
# .env 파일을 복사해서 실제 값을 채운다: cp .env.example .env
# .env는 절대 커밋하지 않는다 (.gitignore에 포함됨)

# ─── 공통 ───
COMPANY_ID=company-a
USE_MOCK_ADAPTERS=true

# ─── GBrain HTTP MCP (Phase 2) ───
# gbrain serve --http 기동 후 설정
# 연결 전 docs/embedding-provider-decision.md 검토 필수
# GBRAIN_MCP_URL=http://localhost:3131/mcp
# GBRAIN_TOKEN=gbrain_xxx

# ─── GBrain 임베딩 (Phase 2) ───
# 기본값: Ollama 로컬 (외부 전송 없음, 승인 불필요)
# 설치 방법: docs/ollama-setup.md
# GBRAIN_EMBEDDING_PROVIDER=ollama
# GBRAIN_EMBEDDING_MODEL=nomic-embed-text
# GBRAIN_EMBEDDING_BASE_URL=http://localhost:11434
#
# 외부 제공자 전환 시 docs/embedding-provider-decision.md에 기록 + 사람 승인 필수:
# GBRAIN_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ─── Google OAuth (Phase 2) ───
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
# GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ─── Supabase (Phase 2) ───
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=   ← 절대 공개 저장소에 커밋 금지
