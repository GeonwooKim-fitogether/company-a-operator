# 환경 변수 예시
# 실제 값을 채워 .env 파일로 저장한다. .env는 절대 커밋하지 않는다.

# 회사 식별자
COMPANY_ID=company-a

# GBrain / Supabase 연결
# GBRAIN_API_URL=https://your-gbrain-instance.com
# GBRAIN_API_KEY=your-gbrain-api-key
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Drive 연결
# GOOGLE_OAUTH_CLIENT_ID=your-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token
# GOOGLE_DRIVE_ROOT_FOLDER_ID=your-approved-root-folder-id

# 실행 모드
# USE_MOCK_ADAPTERS=true   # true이면 Mock Adapter 사용 (Phase 1 기본값)
